<nav class="mt-4 flex flex-col text-left">
  <h4 class="font-semibold text-gray-700 mt-6 uppercase">Projects</h4>
  <ul class="mt-2">
    {% for post in projects %}
      <li class="ml-2">
        <a href="{{ post.relative_url }}" class="group flex items-start py-1 text-gray-600 hover:text-sky-900">
          <svg width="3" height="24" viewBox="0 -9 3 24" class="mr-2 text-gray-400 overflow-visible group-hover:text-gray-600">
            <path d="M0 0L3 3L0 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
          </svg>
          {{ post.title }}
        </a>
      </li>
    {% endfor %}
    <li>
      <a href="/about" class="group flex items-start py-1 text-gray-600 hover:text-sky-900">
        About
      </a>
    </li>
  </ul>
</nav>
